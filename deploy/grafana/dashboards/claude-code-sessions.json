{
  "__inputs": [
    {
      "name": "DS_MIMIR",
      "label": "Mimir",
      "description": "Mimir/Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki datasource",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    },
    {
      "name": "DS_TEMPO",
      "label": "Tempo",
      "description": "Tempo datasource",
      "type": "datasource",
      "pluginId": "tempo",
      "pluginName": "Tempo"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Per-session Claude Code analysis using Loki log events and Tempo traces",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "Usage Overview",
      "tooltip": "Jump to usage overview",
      "type": "link",
      "url": "/d/claude-code-usage/claude-code-usage-overview"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "API Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Duration (ms)",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "API Request Latency",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "quantile_over_time(0.50, {service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.api_request\" | session_id=~\"$session_id\" | unwrap duration_ms [$__interval]) by ()",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "quantile_over_time(0.95, {service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.api_request\" | session_id=~\"$session_id\" | unwrap duration_ms [$__interval]) by ()",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "quantile_over_time(0.99, {service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.api_request\" | session_id=~\"$session_id\" | unwrap duration_ms [$__interval]) by ()",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Errors",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "API Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (status_code) (count_over_time({service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.api_error\" | session_id=~\"$session_id\" [$__interval]))",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Tokens",
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "input" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "output" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "cache_read" },
            "properties": [{ "id": "color", "value": { "fixedColor": "super-light-green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "cache_creation" },
            "properties": [{ "id": "color", "value": { "fixedColor": "super-light-blue", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Tokens Per Request",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(sum_over_time({service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.api_request\" | session_id=~\"$session_id\" | unwrap input_tokens [$__interval])) by ()",
          "legendFormat": "input",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(sum_over_time({service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.api_request\" | session_id=~\"$session_id\" | unwrap output_tokens [$__interval])) by ()",
          "legendFormat": "output",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(sum_over_time({service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.api_request\" | session_id=~\"$session_id\" | unwrap cache_read_tokens [$__interval])) by ()",
          "legendFormat": "cache_read",
          "refId": "C"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(sum_over_time({service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.api_request\" | session_id=~\"$session_id\" | unwrap cache_creation_tokens [$__interval])) by ()",
          "legendFormat": "cache_creation",
          "refId": "D"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Tool Usage",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Count" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge"
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Avg Duration (ms)" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "decimals", "value": 0 },
              { "id": "custom.width", "value": 140 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Success Rate" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 120 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 0.9 },
                    { "color": "green", "value": 0.99 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "gauge"
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 10 },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "enablePagination": true, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      },
      "title": "Tool Usage Breakdown",
      "type": "table",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line"
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (tool_name) (count_over_time({service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.tool_result\" | session_id=~\"$session_id\" [$__range]))",
          "legendFormat": "",
          "refId": "count",
          "instant": true
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "avg by (tool_name) (avg_over_time({service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.tool_result\" | session_id=~\"$session_id\" | unwrap duration_ms [$__range]))",
          "legendFormat": "",
          "refId": "duration",
          "instant": true
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (tool_name) (count_over_time({service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.tool_result\" | session_id=~\"$session_id\" | success=\"true\" [$__range])) / sum by (tool_name) (count_over_time({service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.tool_result\" | session_id=~\"$session_id\" [$__range]))",
          "legendFormat": "",
          "refId": "success_rate",
          "instant": true
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Invocations",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 10 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Top Bash Commands",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (bash_command) (count_over_time({service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.tool_result\" | session_id=~\"$session_id\" | tool_name=\"Bash\" | bash_command!=\"\" [$__interval]))",
          "legendFormat": "{{bash_command}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 102,
      "title": "Events & Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "id": 6,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "Skill Activations",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.skill_activated\" | session_id=~\"$session_id\" | line_format \"{{.skill_name}} ({{.skill_source}})\"",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "id": 7,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "API Errors",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.api_error\" | session_id=~\"$session_id\" | line_format \"[{{.status_code}}] {{.model}}: {{.error}} (attempt {{.attempt}}, {{.duration_ms}}ms)\"",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 103,
      "title": "Traces",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "traceID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View in Tempo",
                    "url": "",
                    "internal": {
                      "datasourceUid": "${DS_TEMPO}",
                      "datasourceName": "Tempo",
                      "query": {
                        "queryType": "traceql",
                        "query": "${__value.raw}"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "duration_ms" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "decimals", "value": 0 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 5000 },
                    { "color": "red", "value": 30000 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "gauge"
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "cost_usd" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "id": 8,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "enablePagination": true, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Time" }]
      },
      "title": "API Requests with Trace Links",
      "type": "table",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "id": true,
              "tsNs": true,
              "labels": true
            },
            "indexByName": {},
            "renameByName": {
              "Time": "Time",
              "model": "Model",
              "duration_ms": "Duration",
              "cost_usd": "Cost",
              "input_tokens": "Input Tokens",
              "output_tokens": "Output Tokens",
              "cache_read_tokens": "Cache Read",
              "speed": "Speed",
              "traceID": "traceID"
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service_name=~\"claude-code|workshop-backend\"} |= \"claude_code.api_request\" | session_id=~\"$session_id\"",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["claude-code", "opentelemetry", "ai", "sessions"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Mimir",
        "multi": false,
        "name": "DS_MIMIR",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "DS_LOKI",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Tempo",
        "multi": false,
        "name": "DS_TEMPO",
        "options": [],
        "query": "tempo",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values({service_name=~\"claude-code|workshop-backend\"}, session_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Session ID",
        "multi": false,
        "name": "session_id",
        "options": [],
        "query": {
          "label": "session_id",
          "stream": "{service_name=~\"claude-code|workshop-backend\"}",
          "type": 1
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "timezone": "browser",
  "title": "Claude Code / Session Deep Dive",
  "uid": "claude-code-sessions",
  "version": 1
}