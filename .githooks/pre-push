#!/usr/bin/env bash
# Pre-push hook: run fast backend + frontend tests before allowing a push.
#
# Install by running `make install-hooks` once after cloning. To bypass
# in an emergency, use `git push --no-verify`.

set -e

# Resolve repo root so the hook works regardless of the caller's cwd.
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "▶ Running backend tests..."
if ! make -s test-unit; then
    echo "✗ Backend tests failed. Fix them or rerun with git push --no-verify to bypass."
    exit 1
fi

echo "▶ Running frontend tests..."
if ! make -s test-frontend; then
    echo "✗ Frontend tests failed. Fix them or rerun with git push --no-verify to bypass."
    exit 1
fi

echo "✓ All tests passed — proceeding with push."
